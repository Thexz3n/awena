# ─── Application ────────────────────────────────────────────────
APP_NAME="Signslator API"
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

# ─── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Database (MySQL) ───────────────────────────────────────────
# Replace with your MySQL credentials. The DB itself ("signslator")
# will be created automatically if it doesn't exist.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=signslator

# ─── Security (JWT) ─────────────────────────────────────────────
# IMPORTANT: change SECRET_KEY in production!
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_super_long_random_secret_at_least_64_chars_replace_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Password reset ─────────────────────────────────────────────
RESET_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ───────────────────────────────────────────────────────
# Comma-separated. For dev, "*" is fine. In production list explicit origins.
CORS_ORIGINS=*

# ─── Rate limiting ──────────────────────────────────────────────
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_SIGNUP=5/minute
RATE_LIMIT_FORGOT=3/minute

# ─── Defaults ───────────────────────────────────────────────────
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ckb
