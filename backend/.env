# ─── Application ────────────────────────────────────────────────
APP_NAME="Awena API"
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

# ─── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Database (MySQL) ───────────────────────────────────────────
# Replace with your MySQL credentials. The DB itself ("signslator")
# will be created automatically if it doesn't exist.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=awena

# ─── Security (JWT) ─────────────────────────────────────────────
# IMPORTANT: change SECRET_KEY in production!
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=RQ2k9-guCfPrvubWk7KXL3C8MaBEAWrNzS5kQZDkJ14rCVDYpvSG8kzAxko9Ij3iZkiwsXOGbt1vVFXpoj0z9w
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Password reset ─────────────────────────────────────────────
RESET_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ───────────────────────────────────────────────────────
# Comma-separated. For dev, "*" is fine. In production list explicit origins.
CORS_ORIGINS=*

# ─── Rate limiting ──────────────────────────────────────────────
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_SIGNUP=5/minute
RATE_LIMIT_FORGOT=3/minute

# ─── Defaults ───────────────────────────────────────────────────
DEFAULT_LANGUAGE=ku
SUPPORTED_LANGUAGES=en,ku
GOOGLE_CLIENT_ID=362352557674-lrvlgjadjsua90h984blb4tpmqgkrfb8.apps.googleusercontent.com
FACEBOOK_APP_ID=your_facebook_app_id_here

# ─── SMTP Email Settings (Optional for Real Reset Emails) ──────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=izujoqez488@gmail.com
SMTP_PASSWORD=xyig tiyg avac oivk
